# ─── LLM (set at least one: Groq and/or OpenAI) ──────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# auto | openai | groq  (auto prefers OpenAI when OPENAI_API_KEY is set)
LLM_PROVIDER=auto

# ─── Embeddings ───────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ─── ChromaDB ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chromadb

# ─── Data paths ───────────────────────────────────────────────
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
PDF_DIR=./data/raw/pdfs

# ─── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── KAP Scraping ─────────────────────────────────────────────
KAP_BASE_URL=https://www.kap.org.tr
KAP_REQUEST_DELAY=1.5

# ─── News ─────────────────────────────────────────────────────
# (Optional) NewsAPI key for additional news sources
NEWS_API_KEY=

# ─── Supabase (Optional) ──────────────────────────────────────
# For logging queries and analytics
SUPABASE_URL=
SUPABASE_KEY=
